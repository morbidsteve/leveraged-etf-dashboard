# API Keys for Price Data
# Choose one of the following providers and configure accordingly

# Yahoo Finance (via yahoo-finance2) - No API key required for basic usage

# Alpha Vantage (25 requests/day free tier)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key

# Finnhub (free tier with WebSocket support)
FINNHUB_API_KEY=your_finnhub_key

# Polygon.io (free tier with delayed data)
POLYGON_API_KEY=your_polygon_key

# Twelve Data (800 requests/day free tier)
TWELVE_DATA_API_KEY=your_twelve_data_key

# Database Configuration (Supabase)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Application Settings
NEXT_PUBLIC_DEFAULT_TICKER=TQQQ
NEXT_PUBLIC_RSI_PERIOD=250
NEXT_PUBLIC_RSI_OVERBOUGHT=55
NEXT_PUBLIC_RSI_OVERSOLD=50

# ── Schwab Trader API (optional; required only when connecting to a broker) ──
# Register your app at https://developer.schwab.com/, wait for "Ready for Use"
# status (1-3 business days), then copy these values from the app's settings.
SCHWAB_CLIENT_ID=your_app_key_from_schwab_dashboard
SCHWAB_CLIENT_SECRET=your_app_secret_from_schwab_dashboard
# Must match exactly what you registered in the Schwab app dashboard.
# For Cloudflare-tunneled deployments use your public domain.
SCHWAB_REDIRECT_URI=https://your-domain.com/api/schwab/callback
# 32+ random chars used to encrypt OAuth tokens at rest. Generate once with:
#   openssl rand -hex 32
# DO NOT change this after tokens are stored — it would invalidate them.
SCHWAB_TOKEN_ENCRYPTION_KEY=replace_me_with_32_plus_random_hex_chars

# Optional: pin the dashboard to a specific Schwab account hash.
# Enforced server-side — even if you OAuth additional accounts, only this
# one will be tradeable. Get the hash by connecting once without this set
# and reading it from the SchwabConnectCard, OR via:
#   docker logs leveraged-etf-dashboard | grep "accounts authorized"
# SCHWAB_ACCOUNT_HASH=

# ── Server-side order guardrails (defense in depth) ────────────────
# Hard caps enforced in the place-order route. Each set to 0 / unset = no cap.
# Recommended: set all of these before enabling any 'auto' mode strategy.

# Maximum notional ($) for any single order. Orders larger than this are
# rejected before they hit Schwab.
SCHWAB_MAX_ORDER_NOTIONAL=5000

# Maximum orders submitted per UTC day across all strategies.
SCHWAB_MAX_ORDERS_PER_DAY=20

# Comma- or space-separated list of allowed symbols. Empty = no allowlist.
# Hugely reduces blast radius if the dashboard is compromised — only the
# symbols you actually trade can be ordered.
SCHWAB_SYMBOL_ALLOWLIST=SOXL,TQQQ,SOXS,SQQQ,UPRO,TNA

# ── LLM chat (optional — chat falls back to local interpreter without these) ──
# Configure either OPENAI_API_KEY or ANTHROPIC_API_KEY. If both are set,
# Anthropic is preferred. Without a key, the StrategyChat UI continues to
# work using its deterministic local question recognizer.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini   # default model for OpenAI calls

# ── Observability (optional) ───────────────────────────────────────
# Future hookup point for Sentry. /api/log already accepts client errors
# and emits them as structured JSON; add SENTRY_DSN here when wiring.
# SENTRY_DSN=

# ── Server-resident strategy worker (Sprint 13, opt-in) ────────────
# When enabled, the Next.js server runs the strategy engine independent
# of any browser tab. Currently a "shadow run" — logs what would have
# fired but does NOT place broker orders (browser engine still owns
# execution until the OCO + reconciliation work lands in a follow-up).
#
# The worker lazy-starts on first GET /api/worker/status.
# SERVER_WORKER_ENABLED=1
#
# Where the worker persists its state file. Defaults to /app/data inside
# the Docker container (matches the order-audit log location).
# WORKER_DATA_DIR=/app/data
